# Root env for docker-compose (Postgres/Redis). Copy to .env and fill in.
# Keep this password in sync with the one in backend/.env DATABASE_URL.
# NOTE: POSTGRES_PASSWORD only takes effect when the pg volume is first
# created. To change it on an existing DB, run:
#   docker exec mintflow-pg psql -U postgres -c "ALTER USER postgres PASSWORD 'NEWPASS';"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=mintflow_db
