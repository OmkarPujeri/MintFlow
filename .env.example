# Root env for docker-compose (Postgres/Redis/API). Copy to .env and fill in.
#
#   cp .env.example .env
#
# Keep POSTGRES_PASSWORD in sync with backend/.env DATABASE_URL if you also run
# the backend directly on the host.
#
# NOTE: POSTGRES_PASSWORD only takes effect when the pg volume is first created.
# To change it on an existing DB:
#   docker exec mintflow-pg psql -U postgres -c "ALTER USER postgres PASSWORD 'NEWPASS';"

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=mintflow_db

# --- API ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_HEX
ENVIRONMENT=development
DEBUG=False
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
