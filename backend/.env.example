APP_NAME=MintFlow
DEBUG=True

# Database
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/mintflow_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
# Generate a strong key, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google Sign-In — Web OAuth Client ID from Google Cloud Console → Credentials.
# The SAME value must be passed to the Flutter build via --dart-define=GOOGLE_CLIENT_ID.
# Leave empty to disable Google login.
GOOGLE_CLIENT_ID=

# AWS S3 (leave empty for now, use video URLs in MVP)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=mintflow-videos
AWS_REGION=ap-south-1
