APP_NAME=MintFlow
DEBUG=True

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/mintflow_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=generate_your_own_32_byte_secure_hex_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3 (leave empty for now, use video URLs in MVP)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=mintflow-videos
AWS_REGION=ap-south-1
